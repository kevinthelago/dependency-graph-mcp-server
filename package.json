{
  "name": "dependency-graph-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing a dependency graph of your codebase",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "dep-graph-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.3",
    "graphology": "^0.26.0",
    "simple-git": "^3.36.0",
    "smol-toml": "^1.6.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cpp": "^0.23.4",
    "web-tree-sitter": "^0.26.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tree-sitter-rust": "^0.24.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter",
      "tree-sitter-c",
      "tree-sitter-cpp"
    ]
  }
}
